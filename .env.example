# =========================================================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# .env 已被 .gitignore 排除，不会被提交到版本库。
# =========================================================================

# --- LLM（可选，不配置则跳过翻译/摘要增强）---
# DeepSeek API（优先使用，留空则跳过）
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama 本地 LLM（DeepSeek 不可用时的回落）
# 确保 ollama serve 正在运行
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_TIMEOUT=300

# --- INFORMS / Marketing Science 摘要补抓 ---
# 优先级：Playwright 持久化 profile → Scrapling → S2
# 首次使用：设 INFORMS_PW_HEADLESS=0，运行后手动过一次 Turnstile，
# 后续 cookie 保存在 data/.pw-profile/，可切回 headless=1。
INFORMS_PAGE_TIMEOUT_MS=25000
# Playwright 持久化 profile（绕过 Cloudflare Turnstile）
INFORMS_PW_HEADLESS=1
# INFORMS_PW_PROFILE_DIR=data/.pw-profile

# Scrapling 浏览器 stealth 模式（默认关闭，CI 中不兼容）
INFORMS_USE_STEALTH=0
INFORMS_STEALTH_HEADLESS=1
INFORMS_SOLVE_CLOUDFLARE=0
INFORMS_REAL_CHROME=1
# INFORMS_USER_DATA_DIR=.cache/informs_chrome

# --- 邮件推送（GitHub Actions 自动发信）---
# 本地运行不需要填；只在 CI 中通过 secrets 注入
# SMTP_PASSWORD 用邮箱的「应用专用密码」，不要用登录密码
#   Gmail:       SMTP_SERVER=smtp.gmail.com, SMTP_PORT=587, 需开启「两步验证」并生成应用密码
#   QQ 邮箱:    SMTP_SERVER=smtp.qq.com,    SMTP_PORT=587, 在设置→账户中开启 SMTP 并获取授权码
#   163 邮箱:   SMTP_SERVER=smtp.163.com,  SMTP_PORT=25,  在设置中开启 SMTP 并获取授权码
#   Outlook:    SMTP_SERVER=smtp-mail.outlook.com, SMTP_PORT=587
# SMTP_SERVER=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=      # 留空则默认等于 SMTP_USERNAME
# NOTIFY_EMAIL=  # 收件地址，多个用逗号分隔
